{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "notes",
  "version": "0.1.3",
  "identifier": "com.p2pnotes.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "notes",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost; font-src 'self' data:; connect-src ipc: http://ipc.localhost https://github.com https://objects.githubusercontent.com https://api.github.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY5NUIxNTE2NkUwRTU0RTcKUldUblZBNXVGaFZiYVdCTHpra21hWi9VUnd1ckhjbXR5eTZVUEhLaUNrdzNQUTdRMS9wT0Y0VlEK",
      "endpoints": [
        "https://github.com/doitwithbrio/notes/releases/latest/download/latest.json"
      ]
    }
  }
}
